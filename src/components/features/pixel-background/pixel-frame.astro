---
/**
 * Pixel Frame Component
 * Container for framed pixel background in hero section
 * Based on PRD: Mode A - Framed
 */

import { PixelBackground } from '@/components/features/pixel-background/pixel-background';
import { cn } from '@/lib/utils';

interface Props {
  class?: string;
}
---

<div class={cn("pixel-frame", "relative overflow-hidden", "border border-border", "p-6 md:p-12", "min-h-[500px] flex-1 flex items-center justify-center", Astro.props.class)}>
  <PixelBackground mode="framed" client:load />
  <div class="relative z-10">
    <slot />
  </div>
</div>

<style>
  .pixel-frame {
    background-color: var(--color-background);
    /* CRT monitor / terminal window feel */
  }
</style>
