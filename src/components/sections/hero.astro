---
/**
 * Hero Section
 * Based on PRD: Name + Title + Tagline
 * Clean, direct, brutalist
 */

import { SITE_CONFIG } from '@/config/site'
---

<section class='flex-1 flex flex-col justify-center pt-16 h-150'>
  <div class='container'>
    <div class='max-w-3xl'>
      <h1 class='font-mono text-4xl md:text-5xl lg:text-6xl font-bold mb-4'>
        {SITE_CONFIG.name}
      </h1>

      <p class='font-mono text-xl md:text-2xl text-secondary mb-6'>
        {SITE_CONFIG.title}
      </p>

      <div class='space-y-2 text-lg md:text-xl text-muted'>
        <p>Building systems that scale.</p>
        <p>Shipping products that matter.</p>
      </div>
    </div>
  </div>
</section>
