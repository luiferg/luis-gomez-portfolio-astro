---
/**
 * 404 Page
 * Custom styled to match site aesthetic
 */

import BaseLayout from '@/layouts/base-layout.astro';
import Header from '@/components/layout/header.astro';
import Footer from '@/components/layout/footer.astro';
import { PAGE_SEO } from '@/config/seo';
---

<BaseLayout title={PAGE_SEO.notFound.title} description={PAGE_SEO.notFound.description}>
  <Header />
  
  <main class="min-h-screen flex flex-col justify-center">
    <div class="container text-center">
      <p class="font-mono text-8xl md:text-9xl font-bold mb-4">404</p>
      <p class="font-mono text-xl text-secondary mb-8">
        Page not found.
      </p>
      <a 
        href="/" 
        class="font-mono inline-flex items-center gap-2 text-muted hover:text-primary transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Back home
      </a>
    </div>
  </main>
  
  <Footer />
</BaseLayout>
