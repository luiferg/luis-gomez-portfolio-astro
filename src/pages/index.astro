---
/**
 * Home Page
 * Single-page portfolio
 * Based on PRD v2.0
 */

import BaseLayout from '@/layouts/base-layout.astro'
import Header from '@/components/layout/header.tsx'
import Footer from '@/components/layout/footer.astro'
import EdgeGuides from '@/components/layout/edge-guides.astro'
import SectionBorder from '@/components/layout/section-border.astro'
import { PixelBackground } from '@/components/features/pixel-background/pixel-background'
import Hero from '@/components/sections/hero.astro'
import Experience from '@/components/sections/experience.astro'
import Contact from '@/components/sections/contact.astro'
import { SITE_CONFIG } from '@/config/site'

// Get pixel background mode from config
const pixelMode = SITE_CONFIG.pixelBackgroundMode
---

<BaseLayout>
  <!-- Edge guides for content sections -->
  <EdgeGuides />

  <Header client:load />

  <main>
    <!-- Hero Section with guided pixel background -->
    <!-- Pixels appear between edge guides, fade at bottom -->
    <section class='relative'>
      <PixelBackground mode={pixelMode} height={650} client:load />
      <div class='relative z-10'>
        <Hero />
      </div>
    </section>

    <SectionBorder />

    <Experience />

    <SectionBorder />

    <Contact />
  </main>

  <Footer />
</BaseLayout>
