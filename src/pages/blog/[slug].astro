---
/**
 * Blog Post Page
 * Renders individual blog posts from markdown
 */

import BaseLayout from '@/layouts/base-layout.astro'
import Header from '@/components/layout/header.tsx'
import Footer from '@/components/layout/footer.astro'
import EdgeGuides from '@/components/layout/edge-guides.astro'
import Tag from '@/components/ui/tag.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('thoughts')
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await render(post)

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  })
}

// Calculate reading time (rough estimate: 200 words per minute)
const wordCount = post?.body?.split(/\s+/).length || 0
const readingTime = Math.ceil(wordCount / 200)
---

<BaseLayout
  title={`${post.data.title} | Luis Gómez`}
  description={post.data.description}
>
  <EdgeGuides />
  <Header client:load />

  <main class='py-16'>
    <article class='container py-16 max-w-3xl'>
      <!-- Header -->
      <header class='mb-12'>
        <a
          href='/blog'
          class='font-mono text-xs text-muted hover:text-secondary transition-colors'
        >
          ← Back to Thoughts
        </a>

        <h1
          transition:name={`post-${post.id}`}
          class='font-mono text-2xl md:text-3xl font-bold mt-6 mb-6'
        >
          {post.data.title}
        </h1>

        <div class='flex flex-wrap items-center gap-3 text-xs text-muted'>
          <time datetime={post.data.publishedAt.toISOString()}>
            {formatDate(post.data.publishedAt)}
          </time>
          <span class='text-border'>·</span>
          <span>{readingTime} min read</span>

          {
            post.data.tags && (
              <>
                <span class='text-border'>·</span>
                <div class='flex gap-2'>
                  {post.data.tags.map((tag) => (
                    <Tag label={tag} />
                  ))}
                </div>
              </>
            )
          }
        </div>
      </header>

      <!-- Content -->
      <div class='prose prose-invert prose-mono max-w-none'>
        <Content />
      </div>

      <!-- Footer navigation -->
      <footer class='mt-16 pt-8 border-t border-border'>
        <a
          href='/blog'
          class='font-mono text-xs text-muted hover:text-secondary transition-colors'
        >
          ← All Thoughts
        </a>
      </footer>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  /* Custom prose styles for markdown content */
  .prose-mono {
    --tw-prose-body: var(--color-secondary);
    --tw-prose-headings: var(--color-primary);
    --tw-prose-links: var(--color-primary);
    --tw-prose-bold: var(--color-primary);
    --tw-prose-code: var(--color-primary);
    --tw-prose-quotes: var(--color-secondary);
  }

  .prose h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .prose h3 {
    font-size: 1.125rem;
    font-weight: 700;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-primary);
  }

  .prose p {
    margin-bottom: 1.25rem;
    line-height: 1.75;
    color: var(--color-secondary);
  }

  .prose ul,
  .prose ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    color: var(--color-secondary);
  }

  .prose li {
    margin-bottom: 0.5rem;
  }

  .prose blockquote {
    border-left: 2px solid var(--color-accent);
    padding-left: 1rem;
    font-style: italic;
    color: var(--color-muted);
  }

  .prose code {
    background: var(--color-surface);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }

  .prose pre {
    background: var(--color-surface);
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }

  .prose pre code {
    background: none;
    padding: 0;
  }

  .prose hr {
    border-color: var(--color-border);
    margin: 2rem 0;
  }

  .prose a {
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition: border-color 150ms ease;
  }

  .prose a:hover {
    border-color: var(--color-secondary);
  }
</style>
