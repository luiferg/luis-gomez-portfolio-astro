---
/**
 * Blog Post Page
 * Renders individual blog posts from markdown
 */

import BaseLayout from '@/layouts/base-layout.astro';
import Header from '@/components/layout/header.tsx';
import Footer from '@/components/layout/footer.astro';
import EdgeGuides from '@/components/layout/edge-guides.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('thoughts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

// Calculate reading time (rough estimate: 200 words per minute)
const wordCount = post.body.split(/\s+/).length;
const readingTime = Math.ceil(wordCount / 200);
---

<BaseLayout 
  title={`${post.data.title} | Luis Gómez`} 
  description={post.data.description}
>
  <EdgeGuides />
  <Header client:load />
  
  <main class="pt-24 pb-16">
    <article class="container py-12 max-w-3xl">
      <!-- Header -->
      <header class="mb-12">
        <a 
          href="/blog" 
          class="font-mono text-sm text-muted hover:text-secondary transition-colors"
        >
          ← Back to Thoughts
        </a>
        
        <h1 class="font-mono text-3xl md:text-5xl font-bold mt-6 mb-4">
          {post.data.title}
        </h1>
        
        <div class="flex flex-wrap items-center gap-4 text-sm text-muted">
          <time datetime={post.data.publishedAt.toISOString()}>
            {formatDate(post.data.publishedAt)}
          </time>
          <span>·</span>
          <span>{readingTime} min read</span>
          
          {post.data.tags && (
            <>
              <span>·</span>
              <div class="flex gap-2">
                {post.data.tags.map((tag) => (
                  <span class="font-mono text-xs px-2 py-1 bg-surface border border-border text-muted">
                    {tag}
                  </span>
                ))}
              </div>
            </>
          )}
        </div>
      </header>
      
      <!-- Content -->
      <div class="prose prose-invert prose-mono prose-headings:font-mono prose-headings:font-bold prose-p:text-secondary prose-a:text-primary prose-a:no-underline prose-a:border-b prose-a:border-border hover:prose-a:border-secondary prose-a:transition-colors">
        <Content />
      </div>
      
      <!-- Footer navigation -->
      <footer class="mt-16 pt-8 border-t border-border">
        <a 
          href="/blog" 
          class="font-mono text-sm text-muted hover:text-secondary transition-colors"
        >
          ← All Thoughts
        </a>
      </footer>
    </article>
  </main>
  
  <Footer />
</BaseLayout>

<style is:global>
  /* Custom prose styles for markdown content */
  .prose-mono {
    --tw-prose-body: var(--color-secondary);
    --tw-prose-headings: var(--color-primary);
    --tw-prose-links: var(--color-primary);
    --tw-prose-bold: var(--color-primary);
    --tw-prose-code: var(--color-primary);
    --tw-prose-quotes: var(--color-secondary);
  }
  
  .prose h2 {
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  .prose h3 {
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  
  .prose p {
    margin-bottom: 1.25rem;
    line-height: 1.75;
  }
  
  .prose ul, .prose ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  
  .prose li {
    margin-bottom: 0.5rem;
  }
  
  .prose blockquote {
    border-left: 2px solid var(--color-accent);
    padding-left: 1rem;
    font-style: italic;
    color: var(--color-muted);
  }
  
  .prose code {
    background: var(--color-surface);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }
  
  .prose pre {
    background: var(--color-surface);
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }
  
  .prose pre code {
    background: none;
    padding: 0;
  }
  
  .prose hr {
    border-color: var(--color-border);
    margin: 2rem 0;
  }
</style>
