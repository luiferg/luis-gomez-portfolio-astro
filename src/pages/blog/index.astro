---
/**
 * Blog / Thoughts Listing Page
 * Minimalist list of all blog posts
 */

import BaseLayout from '@/layouts/base-layout.astro';
import Header from '@/components/layout/header.tsx';
import Footer from '@/components/layout/footer.astro';
import EdgeGuides from '@/components/layout/edge-guides.astro';
import Tag from '@/components/ui/tag.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('thoughts', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

// Sort by date, newest first
posts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout title="Thoughts | Luis Gómez" description="Thoughts on web development, architecture, and building software.">
  <EdgeGuides />
  <Header client:load />
  
  <main class="pt-24 pb-16">
    <section class="container py-16">
      <h1 class="font-mono text-2xl md:text-3xl font-bold mb-3">Thoughts</h1>
      <p class="text-secondary text-sm mb-12">On building, shipping, and learning.</p>
      
      <div class="space-y-0">
        {posts.map((post) => (
          <article class="group border-t border-border py-8 hover:bg-surface/20 transition-colors duration-200">
            <a href={`/blog/${post.id}`} class="block">
              <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2 mb-3">
                <h2 
                  transition:name={`post-${post.id}`}
                  class="font-mono text-lg md:text-xl font-bold group-hover:text-secondary transition-colors duration-200"
                >
                  {post.data.title}
                </h2>
                <time 
                  datetime={post.data.publishedAt.toISOString()} 
                  class="font-mono text-xs text-muted shrink-0"
                >
                  {formatDate(post.data.publishedAt)}
                </time>
              </div>
              <p class="text-secondary text-sm mb-4 max-w-2xl">
                {post.data.description}
              </p>
              {post.data.tags && (
                <div class="flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <Tag label={tag} />
                  ))}
                </div>
              )}
            </a>
          </article>
        ))}
      </div>
      
      {posts.length === 0 && (
        <p class="text-muted">No posts yet.</p>
      )}
    </section>
  </main>
  
  <Footer />
</BaseLayout>
